NODE_ENV=development
APP_PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=tickets_db
DB_SYNC=true
DB_LOGGING=false

# Generate a unique value. Never use this example value outside local development.
API_KEY=replace-with-a-long-random-value

# Comma-separated origins. Add the exact Power Apps/Automate origins used by the environment.
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
